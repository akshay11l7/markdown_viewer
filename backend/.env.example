# ─── MongoDB ────────────────────────────────────────────────────────────────────
# Get from: https://cloud.mongodb.com
# 1. Create a free account at MongoDB Atlas (https://cloud.mongodb.com)
# 2. Create a new Cluster (free tier M0 is fine)
# 3. Go to "Database Access" → Add a database user with password
# 4. Go to "Network Access" → Add your IP (or 0.0.0.0/0 for dev)
# 5. Go to "Database" → Click "Connect" → "Connect your application"
# 6. Copy the connection string and replace <password> with your DB user password
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/markdown-viewer?retryWrites=true&w=majority

# ─── JWT ────────────────────────────────────────────────────────────────────────
# Any long random string. Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_here

# ─── Backblaze B2 ──────────────────────────────────────────────────────────────
# Get from: https://www.backblaze.com/b2/cloud-storage.html
# 1. Create a free Backblaze account
# 2. Go to "Buckets" → Create a new bucket (set it to "Public" for image previews)
# 3. Copy the bucket name → B2_BUCKET_NAME
# 4. Note the "Endpoint" shown on the bucket page (e.g. s3.us-west-004.backblazeb2.com)
#    → B2_ENDPOINT (add https:// prefix)
#    → B2_REGION is the region part (e.g. us-west-004)
# 5. Go to "App Keys" → Create a new application key
#    → B2_KEY_ID = keyID
#    → B2_APP_KEY = applicationKey (shown ONCE, save it!)
B2_ENDPOINT=https://s3.us-west-004.backblazeb2.com
B2_REGION=us-west-004
B2_KEY_ID=your_backblaze_key_id
B2_APP_KEY=your_backblaze_application_key
B2_BUCKET_NAME=your_bucket_name

# ─── Server ────────────────────────────────────────────────────────────────────
PORT=3001
